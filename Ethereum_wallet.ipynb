import plotly.graph_objects as go
import base64


def save_plot_as_html(plot_data, plot_name):
    # Save static HTML with embedded PNG
    with open(f'{plot_name}.html', 'w') as f:
        f.write("<html><body><h1>Plot</h1>")
        img_bytes = base64.b64encode(plot_data['image']).decode('utf-8')
        f.write(f'<img src="data:image/png;base64,{img_bytes}">')
        f.write("</body></html>")

    # Save interactive HTML
    plot_data['fig'].write_html(f'{plot_name}_interactive.html')


